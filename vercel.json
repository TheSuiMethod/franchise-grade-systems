{
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/franchise-fees-real-cost",
      "destination": "/blog/franchise-fees-real-cost",
      "permanent": true
    },
    {
      "source": "/franchise-hidden-fees",
      "destination": "/blog/franchise-hidden-fees",
      "permanent": true
    },
    {
      "source": "/franchise-red-flags-fdd",
      "destination": "/blog/franchise-red-flags-fdd",
      "permanent": true
    },
    {
      "source": "/how-to-read-franchise-fdd",
      "destination": "/blog/how-to-read-franchise-fdd",
      "permanent": true
    },
    {
      "source": "/is-buying-a-franchise-worth-it",
      "destination": "/blog/is-buying-a-franchise-worth-it",
      "permanent": true
    },
    {
      "source": "/questions-to-ask-franchisees",
      "destination": "/blog/questions-to-ask-franchisees",
      "permanent": true
    },
    {
      "source": "/franchise-alternative-blueprint",
      "destination": "/independent-systems",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/tools",
      "destination": "/tools.html"
    },
    {
      "source": "/fdd-analyzer",
      "destination": "/fdd-analyzer.html"
    },
    {
      "source": "/fdd-analyzer-tool",
      "destination": "/fdd-analyzer-tool.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/expert-review",
      "destination": "/expert-review.html"
    },
    {
      "source": "/blog/franchise-fees-real-cost",
      "destination": "/franchise-fees-real-cost.html"
    },
    {
      "source": "/blog/franchise-hidden-fees",
      "destination": "/franchise-hidden-fees.html"
    },
    {
      "source": "/blog/franchise-red-flags-fdd",
      "destination": "/franchise-red-flags-fdd.html"
    },
    {
      "source": "/blog/how-to-read-franchise-fdd",
      "destination": "/how-to-read-franchise-fdd.html"
    },
    {
      "source": "/blog/is-buying-a-franchise-worth-it",
      "destination": "/is-buying-a-franchise-worth-it.html"
    },
    {
      "source": "/blog/questions-to-ask-franchisees",
      "destination": "/questions-to-ask-franchisees.html"
    },
    {
      "source": "/franchise/mcdonalds",
      "destination": "/mcdonalds.html"
    },
    {
      "source": "/franchise/:slug",
      "destination": "/franchise-directory.html"
    },
    {
      "source": "/independent-systems",
      "destination": "/independent-systems.html"
    },
    {
      "source": "/operations-gap-analyzer",
      "destination": "/operations-gap-analyzer.html"
    },
    {
      "source": "/gap-analyzer-tool",
      "destination": "/gap-analyzer-tool.html"
    },
    {
      "source": "/systems-playbook",
      "destination": "/systems-playbook.html"
    },
    {
      "source": "/playbook-portal",
      "destination": "/playbook-portal.html"
    },
    {
      "source": "/implementation-sprint",
      "destination": "/implementation-sprint.html"
    },
    {
      "source": "/gap-analyzer-confirmed",
      "destination": "/gap-analyzer-confirmed.html"
    },
    {
      "source": "/playbook-confirmed",
      "destination": "/playbook-confirmed.html"
    },
    {
      "source": "/sprint-confirmed",
      "destination": "/sprint-confirmed.html"
    }
  ],
  "headers": [
    {
      "source": "/((?!_next|lib|api).*)\\.(html|htm)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/((?!_next).*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}